{
  "name": "4stem-band-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "songs:manifest": "tsx scripts/generate-song-manifest.ts",
    "songs:validate": "tsx scripts/validate-songs.ts",
    "songs:peaks": "tsx scripts/generate-peaks.ts"
  },
  "dependencies": {
    "wavesurfer.js": "7.12.6"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.6.2",
    "jsdom": "29.1.1",
    "svelte": "5.55.5",
    "svelte-check": "4.4.8",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "overrides": {
    "cookie": "1.1.1"
  }
